## .gitignore for TfsMcpServer (.NET 10 solution)

# ---------------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------------
[Bb]in/
[Oo]bj/
publish/
out/

# ---------------------------------------------------------------------------
# Visual Studio / Rider / VS Code
# ---------------------------------------------------------------------------
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.user
*.userosscache
*.suo
*.userprefs

# ---------------------------------------------------------------------------
# Test results / coverage
# ---------------------------------------------------------------------------
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml
coverage/
**/TestResults/

# ---------------------------------------------------------------------------
# NuGet
# ---------------------------------------------------------------------------
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
.nuget/

# ---------------------------------------------------------------------------
# TFS client DLLs (if anyone falls back to manual references instead of NuGet)
# ---------------------------------------------------------------------------
lib/*.dll

# ---------------------------------------------------------------------------
# Secrets / local configuration
# ---------------------------------------------------------------------------
*.env
.env.local
appsettings.Development.json
appsettings.local.json
secrets.json
**/launchSettings.json

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
